# Backend WebSocket URL
# Dev: ws://localhost:8787/ws
# Prod: wss://your-cloud-run-url/ws
PUBLIC_BACKEND_WS_URL=ws://localhost:8787/ws

# Clerk — from https://dashboard.clerk.com
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
CLERK_SECRET_KEY=sk_test_your-secret-key-here

# PostHog — optional analytics (EU host hardcoded in src/components/posthog.astro)
PUBLIC_POSTHOG_KEY=
