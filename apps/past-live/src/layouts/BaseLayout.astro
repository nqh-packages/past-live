---
/**
 * @what - Base layout for Past, Live
 * @why - Shared HTML shell: fonts, analytics, scanline overlay, dark theme
 */
import "@/styles/global.css";
import PostHog from "@/components/posthog.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Past, Live — History is speaking. Are you?",
  description = "Voice-first time travel. Talk to the dead. They talk back.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: display + mono + serif -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Serif:ital@0;1&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

    <PostHog />
    <slot name="head" />
  </head>

  <body class="bg-background text-foreground font-mono min-h-screen min-h-dvh antialiased">
    <div class="scanline-overlay" aria-hidden="true"></div>
    <div class="grain-overlay" aria-hidden="true"></div>
    <slot />
  </body>
</html>
