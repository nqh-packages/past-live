---
/**
 * @what - Home screen: pick who to call from history
 * @why - Input hub (text / voice / camera) + 3 person+moment cards. Leads to session preview overlay.
 */
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import ScenarioCard from "@/components/ScenarioCard.svelte";
import TopicInput from "@/components/TopicInput.svelte";
import SessionPreview from "@/components/SessionPreview.svelte";

// VITE_* not available in Svelte islands — pass as prop from here
const backendUrl = import.meta.env.VITE_BACKEND_HTTP_URL ?? "http://localhost:8787";

const scenarios = [
  {
    id: "constantinople-1453",
    person: "Constantine XI",
    era: "Constantinople, 1453",
    teaser: "The walls are falling.",
    preset: {
      topic: "Fall of Constantinople 1453",
      userRole: "Emperor's last advisor",
      characterName: "CONSTANTINE XI",
      historicalSetting: "Constantinople, Byzantine Empire",
      year: "1453",
      context: "Mehmed II's Ottoman army has surrounded the city. The harbor chain is your last defense. The walls — unbreached for 1,000 years — are failing. The emperor needs your counsel.",
      voiceName: "Gacrux",
      colorPalette: [
        "oklch(12% 0.04 35)",
        "oklch(16% 0.04 35)",
        "oklch(65% 0.22 35)",
        "oklch(88% 0.03 60)",
        "oklch(40% 0.04 35)",
      ],
    },
  },
  {
    id: "moon-landing-1969",
    person: "Gene Kranz",
    era: "Apollo 11, 1969",
    teaser: "25 seconds of fuel.",
    preset: {
      topic: "Apollo 11 Moon Landing 1969",
      userRole: "Student on the line with Mission Control",
      characterName: "GENE KRANZ",
      historicalSetting: "NASA Mission Control, Houston",
      year: "1969",
      context: "Eagle has only 25 seconds of fuel. The landing site is boulder-strewn. Armstrong is flying manually. You have one call to make — abort or land.",
      voiceName: "Charon",
      colorPalette: [
        "oklch(10% 0.02 240)",
        "oklch(14% 0.02 240)",
        "oklch(60% 0.18 240)",
        "oklch(90% 0.02 200)",
        "oklch(35% 0.03 240)",
      ],
    },
  },
  {
    id: "mongol-empire-1206",
    person: "Jamukha",
    era: "Mongol Steppe, 1206",
    teaser: "The khan rides.",
    preset: {
      topic: "Rise of the Mongol Empire 1206",
      userRole: "Rival tribe leader's envoy",
      characterName: "JAMUKHA",
      historicalSetting: "Mongolian Steppe",
      year: "1206",
      context: "Temüjin has united the steppe tribes and taken the name Genghis Khan. Jamukha — his blood brother turned rival — is weighing his final move. You have found him before the decisive battle.",
      voiceName: "Algenib",
      colorPalette: [
        "oklch(11% 0.03 60)",
        "oklch(15% 0.03 60)",
        "oklch(62% 0.20 60)",
        "oklch(88% 0.04 80)",
        "oklch(38% 0.03 60)",
      ],
    },
  },
];
---

<BaseLayout title="Past, Live — Who do you want to call?">
  <!-- SessionPreview overlay: shown after topic submit or scenario card click -->
  <SessionPreview
    client:load
    backendUrl={backendUrl}
    scenarios={scenarios}
  />

  <main class="flex flex-col items-center min-h-screen px-5 py-16 max-w-md mx-auto">

    <!-- Logo -->
    <h1 class="mb-4">
      <a href="/" class="inline-flex items-baseline gap-0" aria-label="Past Live home">
        <span class="font-serif italic text-foreground/30 text-5xl">Past</span>
        <span class="text-foreground/30 text-5xl font-serif">,</span>
        <span class="font-display text-accent text-5xl tracking-wider ml-1">LIVE</span>
      </a>
    </h1>

    <!-- Hero copy -->
    <p class="font-serif italic text-foreground text-xl text-center leading-relaxed mb-14">
      Who do you want to call?
    </p>

    <!-- Input: three modes (text / voice / camera) -->
    <section class="w-full mb-14" aria-label="Topic input">
      <TopicInput client:load backendUrl={backendUrl} />
    </section>

    <!-- Divider -->
    <p class="text-foreground/20 text-[10px] tracking-[0.2em] uppercase mb-8" aria-hidden="true">
      or pick someone to call
    </p>

    <!-- Person+moment cards -->
    <section class="w-full flex flex-col gap-4 mb-16" aria-label="Historical figures to call">
      {scenarios.map((s) => (
        <ScenarioCard scenario={s} client:visible />
      ))}
    </section>

    <!-- Privacy footer -->
    <footer class="text-foreground/20 text-[10px] tracking-[0.15em] text-center" role="contentinfo">
      no wrong answers<br />
      voice processed live, never recorded
    </footer>
  </main>
</BaseLayout>
