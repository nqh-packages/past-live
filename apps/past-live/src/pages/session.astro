---
/**
 * @what - Session screen for Past, Live
 * @why - In-session UI: countdown, chat log, waveform, mic button, hint bar, timer, text input
 */
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import SessionManager from "@/components/SessionManager.svelte";
import MicButton from "@/components/MicButton.svelte";
import ChatLog from "@/components/ChatLog.svelte";
import SpeakingIndicator from "@/components/SpeakingIndicator.svelte";
import SessionTimer from "@/components/SessionTimer.svelte";
import SessionInput from "@/components/SessionInput.svelte";

const url = new URL(Astro.request.url);
const scenarioId = url.searchParams.get("scenario") ?? undefined;
const topic = url.searchParams.get("topic") ?? undefined;
const micParam = url.searchParams.get("mic") === "1";
const camParam = url.searchParams.get("cam") === "1";

// Guard: no valid session params → redirect to home
if (!scenarioId && !topic) return Astro.redirect('/app');

// VITE_* not available in Svelte islands — must pass as prop from Astro page
const backendWsUrl = import.meta.env.PUBLIC_BACKEND_WS_URL ?? "ws://localhost:8787/ws";

// Build human-readable dispatch line
const dispatchLabel = scenarioId
  ? {
      "constantinople-1453": "constantinople 1453 · emperor's advisor",
      "moon-landing-1969": "apollo 11 · mission control",
      "mongol-empire-1206": "mongol steppe 1206 · khan's rival",
    }[scenarioId] ?? scenarioId
  : topic
  ? `open study: ${topic}`
  : "open session";
---

<BaseLayout title="Past, Live — Session Active">
  <!--
    Color theme injection: reads OKLCH values from sessionStorage (set by SessionPreview overlay)
    and applies them as CSS custom properties on the session root element.
    Validates OKLCH syntax before applying to prevent injection.
  -->
  <script is:inline>
    (function() {
      var OKLCH_RE = /^oklch\(\s*[\d.]+%?\s+[\d.]+\s+[\d.]+\s*\)$/;
      try {
        var raw = sessionStorage.getItem('past-live:preview');
        if (!raw) return;
        var data = JSON.parse(raw);
        var palette = data && Array.isArray(data.colorPalette) ? data.colorPalette : [];
        if (palette.length < 5) return;
        var props = ['--color-background','--color-surface','--color-accent','--color-foreground','--color-muted'];
        var root = document.documentElement;
        palette.forEach(function(val, i) {
          if (props[i] && OKLCH_RE.test(String(val).trim())) {
            root.style.setProperty(props[i], val);
          }
        });
      } catch(_) {}
    })();
  </script>

  <!-- SessionManager: invisible orchestrator — WS lifecycle, countdown, auto-mic -->
  <SessionManager
    client:only="svelte"
    scenarioId={scenarioId}
    topic={topic}
    backendWsUrl={backendWsUrl}
    mic={micParam}
    cam={camParam}
  />

  <main class="flex flex-col min-h-screen min-h-dvh px-4 sm:px-5 py-6 sm:py-8 max-w-md mx-auto">

    <!-- Dispatch status header + timer row -->
    <header class="w-full mb-4">
      <div class="relative pl-[72px]">
        <div class="absolute top-0 left-[60px] bottom-0 w-px bg-accent/8" aria-hidden="true"></div>
        <!-- Avatar badge: small circular character portrait, hydrated from sessionStorage -->
        <div
          class="absolute top-0 left-0 w-8 h-8 rounded-full border border-accent/20 overflow-hidden bg-surface"
          id="avatar-badge"
          aria-label="Character avatar"
        >
          <span class="flex items-center justify-center h-full text-[8px] text-foreground/20" id="avatar-placeholder"></span>
        </div>
        <div class="font-mono text-[10px] text-accent tracking-[0.12em] uppercase">
          &gt; session active
        </div>
        <div class="font-mono text-[10px] text-foreground/30 mt-0.5">
          &gt; {dispatchLabel}
        </div>
      </div>
    </header>

    <!-- Session timer (hidden until 5:00 remaining) -->
    <div class="w-full pl-[72px] mb-4">
      <SessionTimer client:load />
    </div>

    <!-- Scene banner (16:9) — populated from sessionStorage sceneImage -->
    <div
      class="w-full aspect-video rounded-sm border border-border bg-surface overflow-hidden mb-4"
      aria-label="Scene image"
      id="scene-banner"
    >
      <span
        class="flex items-center justify-center h-full font-mono text-[10px] text-foreground/20 tracking-wider"
        id="scene-placeholder"
      >[ scene ]</span>
    </div>

    <!-- Scene + avatar hydration from sessionStorage -->
    <script is:inline>
      (function() {
        try {
          var raw = sessionStorage.getItem('past-live:preview');
          if (!raw) return;
          var data = JSON.parse(raw);

          // 1. Scene banner — full-width 16:9 landscape image
          if (data && data.sceneImage) {
            var banner = document.getElementById('scene-banner');
            var scenePlaceholder = document.getElementById('scene-placeholder');
            if (banner && scenePlaceholder) {
              var sceneImg = document.createElement('img');
              sceneImg.src = 'data:image/jpeg;base64,' + data.sceneImage;
              sceneImg.alt = (data.historicalSetting || 'Historical scene');
              sceneImg.className = 'w-full h-full object-cover';
              sceneImg.width = 768;
              sceneImg.height = 432;
              scenePlaceholder.remove();
              banner.appendChild(sceneImg);
            }
          }

          // 2. Avatar badge — small circular portrait injected into the header
          if (data && data.avatar) {
            var badge = document.getElementById('avatar-badge');
            var avatarPlaceholder = document.getElementById('avatar-placeholder');
            if (badge && avatarPlaceholder) {
              var avatarImg = document.createElement('img');
              avatarImg.src = 'data:image/jpeg;base64,' + data.avatar;
              avatarImg.alt = (data.characterName || 'Character') + ' portrait';
              avatarImg.className = 'w-full h-full object-cover';
              avatarImg.width = 32;
              avatarImg.height = 32;
              avatarPlaceholder.remove();
              badge.appendChild(avatarImg);
            }
          }
        } catch(_) {}
      })();
    </script>

    <!-- Speaking indicator (waveform bars while model speaks) -->
    <div class="flex justify-center mb-3" aria-live="polite">
      <SpeakingIndicator client:load />
    </div>

    <!-- Chat log (character-named messages) — scrollable, flex-1 fills remaining space -->
    <div class="w-full mb-4 flex-1 min-h-0">
      <ChatLog client:load />
    </div>

    <!-- Persistent hint bar -->
    <div
      class="w-full text-center font-mono text-[10px] text-foreground/20 tracking-[0.06em] mb-3"
      aria-label="Interaction hint"
    >
      click mic to mute · or type below
    </div>

    <!-- Mic button — thumb-reachable at bottom of screen -->
    <div class="flex justify-center mb-3">
      <MicButton client:load />
    </div>

    <!-- Text input — always visible, sends via WebSocket -->
    <div class="w-full pb-safe">
      <SessionInput client:load />
    </div>
  </main>
</BaseLayout>
