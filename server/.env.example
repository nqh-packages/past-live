# Gemini API — from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud project for Firestore
# Example: my-project-123456
GOOGLE_CLOUD_PROJECT=your-project-id-here

# GCP project number (used for ADC in Cloud Run)
GOOGLE_CLOUD_PROJECT_NUMBER=your-project-number-here

# Server port (default: 8787)
PORT=8787

# CORS allowed origin
# Dev: http://localhost:7278
# Prod: https://your-frontend-url.com (comma-separated for multiple)
ALLOWED_ORIGIN=http://localhost:7278

# Clerk — for server-side JWT verification (optional for local dev)
CLERK_SECRET_KEY=sk_test_your-secret-key-here

# GCS bucket for persistent image storage
# Create: gsutil mb -l us-central1 gs://past-live-images
GCS_IMAGE_BUCKET=past-live-images

# Local Firestore emulator — dev only
# Run: firebase emulators:start --only firestore
# Then set: FIRESTORE_EMULATOR_HOST=localhost:8080
FIRESTORE_EMULATOR_HOST=
