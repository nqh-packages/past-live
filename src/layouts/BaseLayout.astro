---
/**
 * @what - Base layout for Past, Live
 * @why - Shared HTML shell: fonts, analytics, scanline overlay, dark theme, Clerk auth anchor
 */
import "@/styles/global.css";
import PostHog from "@/components/posthog.astro";
import { SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
import { clerkAppearance } from "@/lib/clerk-appearance";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Past, Live — History is speaking. Are you?",
  description = "Voice-first time travel. Talk to the dead. They talk back.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="theme-color" content="#0f0f0f" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="780" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: non-blocking load via media swap pattern -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Serif:ital@0;1&family=Space+Mono:wght@400;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Serif:ital@0;1&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Serif:ital@0;1&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    </noscript>

    <PostHog />
    <slot name="head" />
  </head>

  <body class="bg-background text-foreground font-mono min-h-screen min-h-dvh antialiased">
    <!-- Skip navigation: WCAG 2.4.1 — first focusable element, visually hidden until focused -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-accent focus:text-background focus:px-4 focus:py-2 focus:rounded-sm focus:font-mono focus:text-xs"
    >
      Skip to content
    </a>

    <div class="scanline-overlay" aria-hidden="true"></div>
    <div class="grain-overlay" aria-hidden="true"></div>

    <!-- Auth anchor: top-right, unobtrusive -->
    <nav class="fixed top-4 right-4 z-50" aria-label="Account">
      <SignedIn>
        <UserButton appearance={clerkAppearance} />
      </SignedIn>
      <SignedOut>
        <a
          href="/sign-in"
          class="inline-flex items-center justify-center min-w-11 min-h-11 font-mono text-2xs tracking-[0.14em] uppercase text-foreground/50 hover:text-foreground/70 transition-colors"
          aria-label="Sign in"
        >sign in</a>
      </SignedOut>
    </nav>

    <slot />
  </body>
</html>
